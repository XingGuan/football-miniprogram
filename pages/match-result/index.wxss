/* pages/match-result/index.wxss - 赛果列表 */
.result-page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f9fb 0%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.loading-wrapper, .error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .error-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.retry-btn {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: #667eea;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 页面头部 */
.page-header {
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx 24rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.page-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.page-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.results-scroll {
  flex: 1;
  height: 0;
  padding: 16rpx 12rpx 24rpx 12rpx;
}

/* 赛果卡片 */
.result-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
}

.result-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

/* 状态指示条 */
.result-status-bar {
  height: 4rpx;
  width: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.result-item.finished .result-status-bar {
  background: linear-gradient(90deg, #52c41a 0%, #85ce61 100%);
}

.result-item.ongoing .result-status-bar {
  background: linear-gradient(90deg, #ff9800 0%, #ffb84d 100%);
}

.result-item.upcoming .result-status-bar {
  background: linear-gradient(90deg, #d9d9d9 0%, #e8e8e8 100%);
}

/* 头部信息 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.league-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.league-name {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: 600;
}

.match-status {
  display: flex;
  gap: 8rpx;
}

.status-badge {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #f0f0f0;
  color: #999;
  font-weight: 500;
}

.status-badge.finished {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.status-badge.ongoing {
  background: rgba(255, 152, 0, 0.15);
  color: #ff9800;
}

.status-badge.upcoming {
  background: rgba(200, 200, 200, 0.2);
  color: #999;
}

.match-time {
  font-size: 20rpx;
  color: #ccc;
  font-weight: 500;
}

/* 对阵信息 */
.match-vs-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 20rpx;
  gap: 12rpx;
}

.team {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.team.home {
  justify-content: flex-end;
}

.team.away {
  justify-content: flex-start;
}

.team-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
}

.vs-box {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60rpx;
}

.vs-text {
  font-size: 18rpx;
  color: #ccc;
  font-weight: 500;
}

/* 比分区 */
.score-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  background: #f8f9fb;
  border-bottom: 1rpx solid #f0f0f0;
}

.score-label {
  font-size: 18rpx;
  color: #999;
  font-weight: 500;
  min-width: 40rpx;
}

.score-display {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-main {
  font-size: 40rpx;
  color: #333;
  font-weight: 700;
  font-family: 'Arial', sans-serif;
  letter-spacing: 2rpx;
}

.result-badge {
  font-size: 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  background: #f0f0f0;
  color: #999;
  font-weight: 600;
  min-width: 50rpx;
  text-align: center;
}

.result-badge.H {
  background: rgba(255, 107, 107, 0.15);
  color: #ff6b6b;
}

.result-badge.D {
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
}

.result-badge.A {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

/* 其他比分 */
.other-scores {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 12rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex: 1;
}

.score-item .label {
  font-size: 18rpx;
  color: #999;
  font-weight: 500;
}

.score-item .value {
  font-size: 24rpx;
  color: #333;
  font-weight: 700;
  font-family: 'Arial', sans-serif;
}

/* 开奖结果 */
.odds-section {
  padding: 12rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.odds-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
  font-size: 18rpx;
}

.odds-label {
  color: #999;
  font-weight: 500;
  min-width: 50rpx;
}

.odds-result {
  flex: 1;
  color: #333;
  font-weight: 600;
}

.odds-value {
  color: #667eea;
  font-weight: 700;
}

.bottom-placeholder {
  height: 20rpx;
}
