<!-- pages/ai-chat/index.wxml -->
<view class="chat-page">
  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <view class="toolbar-left">
      <view class="match-info" wx:if="{{matchInfo}}">
        <text class="match-text">{{matchInfo.homeTeam}} vs {{matchInfo.awayTeam}}</text>
      </view>
    </view>
    <view class="toolbar-right">
      <view class="tool-btn" bindtap="onClearChat">
        <text class="tool-text">清空</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y="true"
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation="true"
    enhanced="true"
    show-scrollbar="false"
    style="height: calc(100vh - 200rpx - {{keyboardHeight}}px)"
  >
    <!-- 欢迎信息 -->
    <view class="welcome-section" wx:if="{{messages.length === 0}}">
      <view class="welcome-icon">
        <image src="/images/logo.png" mode="aspectFit" class="ai-icon" />
      </view>
      <text class="welcome-title">足球分析助手</text>
      <text class="welcome-desc">专业的足球赛事分析，为你提供比赛预测与策略建议</text>
    </view>

    <!-- 快速问题 -->
    <view class="quick-section" wx:if="{{showQuickQuestions && messages.length === 0}}">
      <quick-questions
        title="猜你想问"
        bind:select="onQuestionSelect"
      />
    </view>

    <!-- 消息气泡 -->
    <view
      class="message-item"
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{index}}"
    >
      <message-bubble
        type="{{item.role}}"
        content="{{item.content}}"
        typing="{{item.typing}}"
        markdown="{{item.role === 'assistant'}}"
        bind:typingComplete="onTypingComplete"
      />
    </view>

    <!-- 回答完成后的快速问题 -->
    <view class="quick-section-bottom" wx:if="{{showQuickQuestions && messages.length > 0 && !typing}}" id="msg-{{messages.length}}">
      <quick-questions
        title="继续问我"
        bind:select="onQuestionSelect"
      />
    </view>

    <!-- 底部占位 -->
    <view class="list-footer"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-section safe-area-bottom">
    <!-- 正在生成提示 -->
    <view class="generating-tip" wx:if="{{typing}}">
      <text class="tip-text">AI 正在思考...</text>
      <view class="stop-btn" bindtap="onStopGenerate">
        <text class="stop-text">停止</text>
      </view>
    </view>

    <!-- 输入框 -->
    <view class="input-wrapper">
      <input
        class="chat-input"
        placeholder="输入你的问题..."
        placeholder-class="input-placeholder"
        value="{{inputText}}"
        bindinput="onInputChange"
        bindconfirm="onSend"
        confirm-type="send"
        adjust-position="{{false}}"
        cursor-spacing="20"
        disabled="{{sending}}"
      />
      <view
        class="send-btn {{inputText.trim() && !sending ? 'active' : ''}}"
        bindtap="onSend"
      >
        <text class="send-icon">➤</text>
      </view>
    </view>
  </view>
</view>
