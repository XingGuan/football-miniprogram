/* pages/ai-chat/index.wxss */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #ffffff;
  border-bottom: none;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.toolbar-left {
  flex: 1;
}

.match-info {
  background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
}

.match-text {
  font-size: 24rpx;
  color: #0284c7;
  font-weight: 500;
}

.toolbar-right {
  display: flex;
  gap: 16rpx;
}

.tool-btn {
  padding: 12rpx 24rpx;
  background-color: #f1f5f9;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.tool-btn:active {
  transform: scale(0.96);
}

.tool-btn.active {
  background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%);
}

.tool-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.tool-btn.active .tool-text {
  color: #0284c7;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx 0;
}

/* 欢迎区域 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 40rpx;
}

.welcome-icon {
  margin-bottom: 32rpx;
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #f0f0f0;
}

.ai-icon {
  width: 100rpx;
  height: 100rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.6;
}

/* 快速问题区域 */
.quick-section {
  margin-top: 32rpx;
  padding: 0 24rpx;
}

/* 对话中的快速问题 */
.quick-section-bottom {
  padding: 24rpx;
  animation: fadeInUp 0.3s ease;
}

/* 消息项 */
.message-item {
  margin-bottom: 16rpx;
  animation: fadeInUp 0.3s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.list-footer {
  height: 32rpx;
}

/* 输入区域 */
.input-section {
  background-color: #ffffff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: none;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 生成中提示 */
.generating-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fef9c3 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #d97706;
  font-weight: 500;
  display: flex;
  align-items: center;
}

.tip-text::before {
  content: '';
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  background-color: #f59e0b;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.8);
  }
}

.stop-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.stop-btn:active {
  transform: scale(0.96);
}

.stop-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 输入框容器 */
.input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f1f5f9;
  border-radius: 48rpx;
  padding: 8rpx 8rpx 8rpx 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.input-wrapper:focus-within {
  border-color: #3b82f6;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.1);
}

.chat-input {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  color: #1e293b;
}

.input-placeholder {
  color: #94a3b8;
}

.send-btn {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e2e8f0;
  border-radius: 50%;
  transition: all 0.25s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.4);
}

.send-btn.active:active {
  transform: scale(0.92);
}

.send-icon {
  font-size: 36rpx;
  color: #94a3b8;
  transition: color 0.2s ease;
}

.send-btn.active .send-icon {
  color: #ffffff;
}
