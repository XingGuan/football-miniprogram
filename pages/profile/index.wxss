/* pages/profile/index.wxss */
.profile-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 用户信息区域 */
.user-section {
  background-color: #ffffff;
  padding: 40rpx 24rpx;
  margin-bottom: 20rpx;
}

.user-info,
.login-prompt {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 24rpx;
}

.avatar.default {
  opacity: 0.6;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.phone {
  font-size: 26rpx;
  color: #999;
}

.edit-btn {
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

.edit-text {
  font-size: 26rpx;
  color: #666;
}

/* 未登录状态 */
.login-text {
  font-size: 32rpx;
  color: #333;
}

.login-desc {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 菜单区域 */
.menu-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 操作区域 */
.action-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 28rpx;
}

.action-item:active {
  background-color: #f9f9f9;
}

.action-text {
  font-size: 28rpx;
  color: #666;
}

/* 退出登录 */
.logout-section {
  padding: 24rpx;
}

.logout-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 28rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
}

.logout-btn:active {
  background-color: #fff1f0;
}

.logout-text {
  font-size: 30rpx;
  color: #ff4d4f;
}

/* 版本信息 */
.version-section {
  padding: 40rpx;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: #ccc;
}
