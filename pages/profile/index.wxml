<!-- pages/profile/index.wxml -->
<view class="profile-page">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <!-- 已登录 -->
    <view class="user-info" wx:if="{{isLoggedIn && userInfo}}" bindtap="onEditProfile">
      <image
        class="avatar"
        src="{{userInfo.avatar || '/images/icons/user-avatar.png'}}"
        mode="aspectFill"
      />
      <view class="info">
        <view class="name-row">
          <text class="name">{{userInfo.userName || '用户'}}</text>
          <!-- 最高等级勋章 -->
          <view class="top-medal-wrapper" wx:if="{{topMedal}}" catchtap="onTopMedalTap">
            <view class="top-medal-item {{topMedal.colorClass}}">
              <text class="top-medal-icon">{{topMedal.icon}}</text>
            </view>
            <view class="top-medal-tooltip">累计中奖{{topMedal.bonusDesc}}</view>
          </view>
        </view>
        <text class="phone">{{userInfo.phone || ''}}</text>
      </view>
      <view class="edit-arrow">›</view>
    </view>

    <!-- 积分与签到卡片 -->
    <view class="cards-row" wx:if="{{isLoggedIn && userInfo}}">
      <!-- 积分卡片 -->
      <view class="points-card" bindtap="onPointDetail">
        <view class="points-bg-decoration"></view>
        <view class="points-content">
          <view class="points-icon-wrapper">
            <text class="points-icon">💎</text>
          </view>
          <view class="points-info">
            <text class="points-label">我的积分</text>
            <text class="points-value">{{userInfo.point || 0}}</text>
          </view>
        </view>
        <view class="points-arrow">›</view>
      </view>

      <!-- 签到卡片 -->
      <view class="sign-card {{userInfo.signToday ? 'signed' : ''}}" bindtap="onSign">
        <view class="sign-bg-decoration"></view>
        <view class="sign-content">
          <view class="sign-icon-wrapper">
            <text class="sign-icon">{{userInfo.signToday ? '✓' : '📅'}}</text>
          </view>
          <view class="sign-info">
            <text class="sign-label">{{userInfo.signToday ? '今日已签到' : '每日签到'}}</text>
            <text class="sign-reward">{{userInfo.signToday ? '明天再来' : '+1积分'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 我的勋章入口 -->
    <view class="medal-entry" wx:if="{{isLoggedIn && userInfo && medals.length > 0}}" bindtap="onOpenMedalPopup">
      <view class="medal-entry-left">
        <view class="medal-entry-icon">🏅</view>
        <view class="medal-entry-info">
          <text class="medal-entry-title">我的勋章</text>
          <text class="medal-entry-desc">已获得 {{acquiredCount}} 枚勋章</text>
        </view>
      </view>
      <!-- 已获得的勋章预览 -->
      <view class="medal-entry-preview">
        <view class="preview-medal {{item.colorClass}}" wx:for="{{acquiredMedals}}" wx:key="medalId" wx:if="{{index < 4}}">
          <text>{{item.icon}}</text>
        </view>
      </view>
      <view class="medal-entry-arrow">›</view>
    </view>

    <!-- 任务中心 -->
    <view class="task-section" wx:if="{{isLoggedIn && userInfo}}">
      <view class="task-header">
        <text class="task-title">任务中心</text>
        <text class="task-subtitle">完成任务领积分</text>
      </view>
      <view class="task-list">
        <!-- 完善手机号任务 -->
        <view class="task-item {{userInfo.phone ? 'completed' : ''}}" bindtap="onBindPhone">
          <view class="task-left">
            <view class="task-icon-wrapper">
              <text class="task-icon">📱</text>
            </view>
            <view class="task-info">
              <text class="task-name">完善手机号</text>
              <text class="task-desc">绑定手机号，账号更安全</text>
            </view>
          </view>
          <view class="task-right">
            <text class="task-reward" wx:if="{{!userInfo.phone}}">+5积分</text>
            <text class="task-status" wx:else>已完成</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 拼团活动 -->
    <view class="activity-section" wx:if="{{isLoggedIn && userInfo}}">
      <view class="activity-card" bindtap="onActivityCenter">
        <view class="activity-left">
          <view class="activity-icon-wrapper">
            <text class="activity-icon">🎉</text>
          </view>
          <view class="activity-info">
            <text class="activity-title">拼团得积分</text>
            <text class="activity-desc">邀请好友拼团，完成得积分</text>
          </view>
        </view>
        <view class="activity-arrow">›</view>
      </view>
    </view>

    <!-- 未登录 -->
    <view class="login-prompt" wx:else bindtap="onLogin">
      <image class="avatar default" src="/images/icons/user-avatar.png" mode="aspectFill" />
      <view class="info">
        <text class="login-text">点击登录</text>
        <text class="login-desc">登录后享受更多服务</text>
      </view>
      <view class="arrow">›</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 分享给好友 -->
    <button class="menu-item" open-type="share">
      <view class="menu-left">
        <text class="menu-icon">📤</text>
        <view class="menu-info">
          <text class="menu-title">分享给好友</text>
          <text class="menu-desc">邀请好友一起使用</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </button>

    <!-- 联系客服 -->
    <button class="menu-item" open-type="contact">
      <view class="menu-left">
        <text class="menu-icon">👨‍💼</text>
        <view class="menu-info">
          <text class="menu-title">联系客服</text>
          <text class="menu-desc">24小时在线客服</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </button>

    <!-- 其他菜单 -->
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="title"
      wx:if="{{item.action !== 'contact'}}"
      data-path="{{item.path}}"
      data-action="{{item.action}}"
      bindtap="onMenuTap"
    >
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <view class="menu-info">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 其他操作 -->
  <view class="action-section">
    <view class="action-item" bindtap="onClearCache">
      <text class="action-text">清除缓存</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">Version {{version}}</text>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>

  <!-- 绑定手机号弹窗 -->
  <view class="popup-mask" wx:if="{{showPhonePopup}}" bindtap="onClosePhonePopup">
    <view class="popup-content" catchtap="preventTap">
      <view class="popup-header">
        <text class="popup-title">绑定手机号</text>
        <view class="popup-close" bindtap="onClosePhonePopup">×</view>
      </view>
      <view class="popup-body">
        <view class="popup-tip">绑定手机号可获得 <text class="highlight">5积分</text> 奖励</view>
        <!-- 手机号输入 -->
        <view class="input-group">
          <text class="input-prefix">+86</text>
          <input
            class="input-field"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{bindPhone}}"
            bindinput="onBindPhoneInput"
          />
        </view>
        <!-- 验证码输入 -->
        <view class="input-group">
          <input
            class="input-field code-input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            value="{{bindCode}}"
            bindinput="onBindCodeInput"
          />
          <view
            class="send-code-btn {{bindCountdown > 0 || sendingBindCode ? 'disabled' : ''}}"
            bindtap="onSendBindCode"
          >
            <text wx:if="{{bindCountdown > 0}}">{{bindCountdown}}s</text>
            <text wx:elif="{{sendingBindCode}}">发送中</text>
            <text wx:else>获取验证码</text>
          </view>
        </view>
      </view>
      <view class="popup-footer">
        <view class="popup-btn cancel" bindtap="onClosePhonePopup">取消</view>
        <view class="popup-btn confirm {{bindLoading ? 'loading' : ''}}" bindtap="onConfirmBindPhone">
          {{bindLoading ? '绑定中...' : '确认绑定'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 修改用户名弹窗 -->
  <view class="popup-mask" wx:if="{{showNamePopup}}" bindtap="onCloseNamePopup">
    <view class="popup-content" catchtap="preventTap">
      <view class="popup-header">
        <text class="popup-title">修改用户名</text>
        <view class="popup-close" bindtap="onCloseNamePopup">×</view>
      </view>
      <view class="popup-body">
        <view class="popup-tip">输入新的用户名</view>
        <!-- 用户名输入 -->
        <view class="input-group">
          <input
            class="input-field"
            type="text"
            maxlength="20"
            placeholder="请输入用户名（不超过20个字符）"
            value="{{newUserName}}"
            bindinput="onUserNameInput"
          />
        </view>
      </view>
      <view class="popup-footer">
        <view class="popup-btn cancel" bindtap="onCloseNamePopup">取消</view>
        <view class="popup-btn confirm {{updateNameLoading ? 'loading' : ''}}" bindtap="onConfirmUpdateName">
          {{updateNameLoading ? '修改中...' : '确认修改'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 我的勋章弹窗 -->
  <view class="medal-popup-mask" wx:if="{{showMedalPopup}}" catchtap="onCloseMedalPopup">
    <view class="medal-popup-container" catchtap="preventTap">
      <!-- 头部 -->
      <view class="medal-popup-header">
        <view class="medal-popup-close" catchtap="onCloseMedalPopup">
          <text class="close-icon">×</text>
        </view>
        <view class="medal-popup-title-area">
          <text class="medal-popup-title">🏅 我的勋章</text>
        </view>
        <!-- 统计信息 -->
        <view class="medal-stats-row">
          <view class="stat-badge">
            <text class="stat-badge-num">{{medals.length}}</text>
            <text class="stat-badge-label">全部</text>
          </view>
          <view class="stat-badge acquired">
            <text class="stat-badge-num">{{acquiredCount}}</text>
            <text class="stat-badge-label">已获得</text>
          </view>
          <view class="stat-badge worn">
            <text class="stat-badge-num">{{wornMedals.length}}</text>
            <text class="stat-badge-label">佩戴中</text>
          </view>
        </view>
      </view>

      <!-- 勋章列表 -->
      <scroll-view class="medal-popup-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="medal-grid-list">
          <view
            class="medal-grid-item {{item.isAcquired ? 'acquired' : 'locked'}}"
            wx:for="{{medals}}"
            wx:key="medalId"
            bindtap="onMedalTap"
            data-medal="{{item}}"
          >
            <!-- 勋章图标 -->
            <view class="medal-icon-box {{item.colorClass}}">
              <text class="medal-icon-text">{{item.icon}}</text>
              <view class="medal-shine" wx:if="{{item.isAcquired}}"></view>
            </view>

            <!-- 状态标签 -->
            <view class="medal-tag worn" wx:if="{{item.isWorn}}">佩戴中</view>
            <view class="medal-tag lock" wx:elif="{{!item.isAcquired}}">🔒</view>

            <!-- 勋章名称 -->
            <text class="medal-name">{{item.medalName}}</text>
            <text class="medal-desc">{{item.medalMeaning}}</text>
          </view>
        </view>

        <!-- 底部提示 -->
        <view class="medal-footer-tip">
          <text>点击已解锁勋章查看详情</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
