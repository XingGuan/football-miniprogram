<!-- pages/profile/index.wxml -->
<view class="profile-page">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <!-- 已登录 -->
    <view class="user-info" wx:if="{{isLoggedIn && userInfo}}">
      <image
        class="avatar"
        src="{{userInfo.avatar || '/images/icons/user-avatar.png'}}"
        mode="aspectFill"
        bindtap="onEditProfile"
      />
      <view class="info">
        <text class="name">{{userInfo.userName || '用户'}}</text>
        <text class="phone">{{userInfo.phone}}</text>
      </view>
    </view>

    <!-- 积分与签到卡片 -->
    <view class="cards-row" wx:if="{{isLoggedIn && userInfo}}">
      <!-- 积分卡片 -->
      <view class="points-card">
        <view class="points-bg-decoration"></view>
        <view class="points-content">
          <view class="points-icon-wrapper">
            <text class="points-icon">💎</text>
          </view>
          <view class="points-info">
            <text class="points-label">我的积分</text>
            <text class="points-value">{{userInfo.point || 0}}</text>
          </view>
        </view>
      </view>

      <!-- 签到卡片 -->
      <view class="sign-card {{userInfo.signToday ? 'signed' : ''}}" bindtap="onSign">
        <view class="sign-bg-decoration"></view>
        <view class="sign-content">
          <view class="sign-icon-wrapper">
            <text class="sign-icon">{{userInfo.signToday ? '✓' : '📅'}}</text>
          </view>
          <view class="sign-info">
            <text class="sign-label">{{userInfo.signToday ? '今日已签到' : '每日签到'}}</text>
            <text class="sign-reward">{{userInfo.signToday ? '明天再来' : '+2积分'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 未登录 -->
    <view class="login-prompt" wx:else bindtap="onLogin">
      <image class="avatar default" src="/images/icons/user-avatar.png" mode="aspectFill" />
      <view class="info">
        <text class="login-text">点击登录</text>
        <text class="login-desc">登录后享受更多服务</text>
      </view>
      <view class="arrow">›</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 联系客服 -->
    <button class="menu-item" open-type="contact">
      <view class="menu-left">
        <text class="menu-icon">👨‍💼</text>
        <view class="menu-info">
          <text class="menu-title">联系客服</text>
          <text class="menu-desc">24小时在线客服</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </button>

    <!-- 其他菜单 -->
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="title"
      wx:if="{{item.action !== 'contact'}}"
      data-path="{{item.path}}"
      data-action="{{item.action}}"
      bindtap="onMenuTap"
    >
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <view class="menu-info">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 其他操作 -->
  <view class="action-section">
    <view class="action-item" bindtap="onClearCache">
      <text class="action-text">清除缓存</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text class="version-text">Version {{version}}</text>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
