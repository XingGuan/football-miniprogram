<view class="container">
  <!-- 头部导航 -->
  <view class="header-nav">
    <view class="header-title-row">
      <text class="header-title">大厅</text>
      <text class="header-badge">🔥 热门方案</text>
    </view>
    <view class="sub-tabs">
      <text class="sub-tab active" data-tab="share" bindtap="switchTab">分享方案</text>
      <text class="sub-tab" data-tab="discover" bindtap="switchTab">数据发现</text>
      <text class="sub-tab" data-tab="winrate" bindtap="switchTab">胜率榜</text>
      <text class="sub-tab" data-tab="amount" bindtap="switchTab">金额榜</text>
    </view>
  </view>

  <!-- 主滚动区域 -->
  <scroll-view scroll-y class="main-scroll">
    <!-- 排行榜区域（可折叠） -->
    <view class="rank-section" wx:if="{{showRank}}">
      <view class="rank-header">
        <text class="rank-header-label">🏆 胜率排行榜</text>
        <text class="rank-toggle" bindtap="toggleRank">收起 ▲</text>
      </view>
      <view class="rank-list">
        <view class="rank-item rank-1">
          <text class="rank-badge">1</text>
          <view class="rank-info">
            <text class="rank-name">足球小王子</text>
            <text class="rank-meta">3中/7单 · 稳健型</text>
          </view>
          <text class="rank-winrate">43%</text>
        </view>
        <view class="rank-item rank-2">
          <text class="rank-badge">2</text>
          <view class="rank-info">
            <text class="rank-name">多特蒙德</text>
            <text class="rank-meta">7中/21单 · 高频型</text>
          </view>
          <text class="rank-winrate">33%</text>
        </view>
      </view>
    </view>

    <!-- 方案卡片列表 -->
    <view wx:for="{{planList}}" wx:key="id" class="plan-card status-{{item.status}}">
      <!-- 顶部：头像 + 昵称 + 状态标签 -->
      <view class="plan-card-top">
        <view class="plan-user-row">
          <image class="plan-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <text class="plan-nickname">{{item.nickname}}</text>
        </view>
        <view class="plan-status-tag tag-{{item.status}}">
          {{item.statusText}}
        </view>
      </view>

      <!-- 用户统计：中奖 / 未中 / 胜率（原本结构优化后） -->
      <view class="user-stats-grid">
        <view class="stat-item" style="background: var(--won-color);">
          <text class="stat-label">中奖</text>
          <text class="stat-value" style="color: var(--won-text-color);">{{item.winRecords}}</text>
        </view>
        <view class="stat-item" style="background: var(--lost-color);">
          <text class="stat-label">未中</text>
          <text class="stat-value" style="color: var(--lost-text-color);">{{item.loseRecords}}</text>
        </view>
        <view class="stat-item" style="background: var(--pedding-color);">
          <text class="stat-label">胜率</text>
          <text class="stat-value" style="color: var(--pedding-text-color);">{{item.winRate}}%</text>
        </view>
      </view>

      <!-- 投注详情网格 -->
      <view class="plan-details-grid">
        <view class="plan-detail-item">
          <text class="plan-detail-value">{{item.totalMatches}}</text>
          <text class="plan-detail-label">比赛总数</text>
        </view>
        <view class="plan-detail-item">
          <text class="plan-detail-value">{{item.selectedMatches}}场</text>
          <text class="plan-detail-label">已选场次</text>
        </view>
        <view class="plan-detail-item">
          <text class="plan-detail-value amount-highlight">{{item.amount}}<text style="font-size:12px;font-weight:600;">元</text></text>
          <text class="plan-detail-label">{{item.status === 'won' ? '中奖金额' : '投注金额'}}</text>
        </view>
      </view>

      <!-- 玩法标签 + 注数 -->
      <view class="plan-tags-row">
        <text wx:for="{{item.betTypes}}" wx:key="*this" class="plan-play-tag">{{item}}</text>
        <text class="plan-note">· {{item.noteCount}}注</text>
      </view>

      <!-- 底部胜率摘要 & 金额 -->
      <view class="plan-summary-row">
        <view class="plan-winrate-display" style="background: {{item.status === 'won' ? '#e6f7f1' : '#f8fafc'}}; border-color: {{item.status === 'won' ? '#c3e8d8' : '#e8ecf2'}};">
          <text class="plan-winrate-num" style="color: {{item.status === 'won' ? '#0d7a55' : '#333'}};">{{item.winRate}}%</text>
          <text class="plan-winrate-label">历史胜率</text>
        </view>
        <view class="plan-total-amount" style="color: {{item.status === 'won' ? '#10a97a' : '#f07b3f'}};">
          {{item.status === 'won' ? '+' : ''}}{{item.amount}}<text style="font-size:12px;font-weight:600;">元</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="bottom-nav">
    <view class="nav-item active">
      <text class="nav-icon">🏠</text>
      <text>大厅</text>
    </view>
    <view class="nav-item">
      <text class="nav-icon">📋</text>
      <text>赛果</text>
    </view>
    <view class="nav-item">
      <text class="nav-icon">🕘</text>
      <text>历史</text>
    </view>
    <view class="nav-item">
      <text class="nav-icon">👤</text>
      <text>我的</text>
    </view>
  </view>
</view>