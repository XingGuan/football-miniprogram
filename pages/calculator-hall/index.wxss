/* pages/calculator-hall/index.wxss - 推荐方案大厅 */
.hall-page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f9fb 0%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.loading-wrapper, .error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .error-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.retry-btn {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: #667eea;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 页面头部 */
.page-header {
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 16rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.title-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.header-share-btn {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.header-share-btn::after {
  border: none;
}

.header-share-btn .share-icon {
  font-size: 28rpx;
  line-height: 1;
}

.page-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}

.page-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

/* 胜率排行榜 */
.rank-section {
  background: #fff;
  margin: 12rpx 12rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.rank-header {
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 100%);
  padding: 10rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rank-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.rank-toggle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.rank-list {
  padding: 8rpx 12rpx;
  max-height: 500rpx;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.rank-list.collapsed {
  max-height: 0;
  padding: 0 12rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 10rpx 6rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-medal {
  width: 40rpx;
  font-size: 28rpx;
  text-align: center;
}

.rank-avatar {
  width: 44rpx;
  height: 44rpx;
  margin-right: 10rpx;
}

.avatar-img {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-fallback {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.rank-user {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rank-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}

.rank-stats {
  font-size: 18rpx;
  color: #999;
}

.rank-rate {
  min-width: 80rpx;
  text-align: right;
}

.rate-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #ff6b6b;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

.recommendations-scroll {
  flex: 1;
  height: 0;
  padding: 12rpx 12rpx 20rpx 12rpx;
}

/* 方案卡片 */
.scheme-item {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
}

.scheme-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

/* 顶部状态条 */
.scheme-status-bar {
  height: 4rpx;
  width: 100%;
}

.scheme-status-bar.win {
  background: linear-gradient(90deg, #ff6b6b 0%, #ff8c8c 100%);
}

.scheme-status-bar.pending {
  background: linear-gradient(90deg, #52c41a 0%, #85ce61 100%);
}

.scheme-status-bar.lose {
  background: linear-gradient(90deg, #d9d9d9 0%, #e8e8e8 100%);
}

/* 用户信息区 */
.scheme-user-section {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  position: relative;
}

.user-avatar-wrapper {
  flex-shrink: 0;
}

.user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 2rpx solid #e8e8e8;
}

.user-avatar-fallback {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  border: 2rpx solid rgba(102, 126, 234, 0.3);
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 6rpx;
  justify-content: space-between;
}

.user-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 700;
  flex: 1;
}

.badge {
  display: flex;
  align-items: center;
  gap: 3rpx;
  padding: 3rpx 8rpx;
  border-radius: 10rpx;
  font-size: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.badge.win {
  background: rgba(255, 107, 107, 0.15);
  color: #ff6b6b;
}

.badge.pending {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.badge.lose {
  background: rgba(200, 200, 200, 0.2);
  color: #999;
}

.badge-icon {
  font-size: 16rpx;
}

.badge-text {
  font-size: 16rpx;
}

.user-stats-row {
  display: flex;
  gap: 6rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 8rpx;
  background: #f8f9fb;
  border-radius: 6rpx;
  gap: 3rpx;
  min-height: 42rpx;
  justify-content: center;
}

.stat-box.highlight {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.08) 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}

.stat-label {
  font-size: 16rpx;
  color: #999;
  font-weight: 500;
}

.stat-value {
  font-size: 20rpx;
  font-weight: 700;
}

.stat-value.win-color {
  color: #ff6b6b;
}

.stat-value.lose-color {
  color: #d9d9d9;
}

.stat-value.rate-color {
  color: #667eea;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, #f0f0f0 0%, #f0f0f0 100%);
  margin: 0 16rpx;
}

/* 方案详情区 */
.scheme-detail-section {
  padding: 10rpx 16rpx 12rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detail-row {
  display: flex;
  gap: 0;
  justify-content: space-around;
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 0;
}

.detail-label {
  font-size: 18rpx;
  color: #999;
  font-weight: 500;
}

.detail-value {
  font-size: 18rpx;
  color: #333;
  font-weight: 800;
}

/* 查看箭头 */
.scheme-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #e8e8e8;
  font-weight: 300;
  opacity: 0.6;
}

.bottom-placeholder {
  height: 20rpx;
}

/* 单关计划浮动按钮 */
.dragon-floating-btn {
  position: fixed;
  width: 100rpx;
  height: 100rpx;
  bottom: auto;
  right: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  cursor: grab;
}

.dragon-floating-btn:active {
  cursor: grabbing;
}

.dragon-btn-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.dragon-floating-btn:active .dragon-btn-inner {
  transform: scale(0.95);
  box-shadow: 0 3rpx 12rpx rgba(102, 126, 234, 0.35);
}

.dragon-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.dragon-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}
