<!-- pages/ai-analysis/index.wxml -->
<view class="page">
  <!-- 比赛信息头部 -->
  <view class="match-header" wx:if="{{matchInfo}}">
    <view class="header-top">
      <text class="league">{{matchInfo.league}}</text>
    </view>
    <view class="teams">
      <text class="team">{{matchInfo.homeTeam}}</text>
      <text class="vs">VS</text>
      <text class="team">{{matchInfo.awayTeam}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="loading-animation">
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
      <view class="loading-dot"></view>
    </view>
    <text class="loading-text">AI 正在分析中...</text>
    <text class="loading-tip">请稍候，这可能需要30秒钟</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrapper" wx:elif="{{error}}">
    <view class="error-icon">!</view>
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="onRetry">重新分析</view>
  </view>

  <!-- 分析结果 -->
  <view class="result-wrapper" wx:elif="{{analysisResult || streaming}}">
    <!-- 生成时间 -->
    <view class="generate-time-bar" wx:if="{{generateTime && !streaming}}">
      <text class="time-icon">🕐</text>
      <text class="time-text">生成时间: {{generateTime}}</text>
    </view>

    <!-- 流式传输状态提示 -->
    <view class="streaming-bar" wx:if="{{streaming}}">
      <view class="streaming-indicator">
        <view class="streaming-dot"></view>
        <view class="streaming-dot"></view>
        <view class="streaming-dot"></view>
      </view>
      <text class="streaming-text">AI 正在生成分析...</text>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar">
      <!-- 获取最新分析按钮 -->
      <view class="refresh-btn {{isVip ? 'vip' : 'disabled'}} {{streaming ? 'loading' : ''}}" bindtap="onGetLatestAnalysis">
        <view class="vip-badge" wx:if="{{!streaming}}">VIP</view>
        <view class="loading-spinner-mini" wx:if="{{streaming}}"></view>
        <text>{{streaming ? '生成中...' : '获取最新'}}</text>
      </view>
      <view class="action-btn" bindtap="onCopy" wx:if="{{!streaming}}">
        <text>复制</text>
      </view>
      <button class="action-btn" open-type="share" wx:if="{{!streaming}}">
        <text>分享</text>
      </button>
      <view class="action-btn delete-btn" wx:if="{{isAdmin && !streaming}}" bindtap="onDelete">
        <text>删除</text>
      </view>
    </view>

    <!-- 内容区域 -->
    <view class="content-card">
      <!-- 流式传输中但还没内容时显示等待 -->
      <view class="stream-waiting" wx:if="{{streaming && !analysisResult}}">
        <text class="waiting-text">等待AI响应...</text>
      </view>

      <!-- 使用 markdown-viewer 组件渲染 -->
      <markdown-viewer wx:if="{{analysisResult}}" content="{{analysisResult}}" />

      <!-- 流式传输时的光标效果 -->
      <view class="typing-cursor" wx:if="{{streaming && analysisResult}}"></view>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>
