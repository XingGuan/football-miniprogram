<!-- pages/activity/index.wxml - 活动中心 -->
<view class="activity-page">
  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrapper" wx:elif="{{error}}">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="onRetry">重试</view>
  </view>

  <!-- 主内容 -->
  <view class="main-content" wx:else>
    <!-- 页面头部 -->
    <view class="page-header">
      <view class="header-content">
        <view class="title-section">
          <text class="page-title">🎉 拼团得积分</text>
          <text class="page-desc">邀请好友一起拼团</text>
        </view>
        <button class="header-btn" bindtap="onOpenCreateModal">
          <text class="btn-icon">➕</text>
          <text class="btn-text">发起拼团</text>
        </button>
      </view>
    </view>

    <!-- 标签栏 -->
    <view class="tabs">
      <view
        class="tab-item {{activeTab === 'created' ? 'active' : ''}}"
        data-tab="created"
        bindtap="onTabChange"
      >
        <text class="tab-label">我发起的</text>
      </view>
      <view
        class="tab-item {{activeTab === 'joined' ? 'active' : ''}}"
        data-tab="joined"
        bindtap="onTabChange"
      >
        <text class="tab-label">我加入的</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{displayGroups.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无拼团</text>
      <text class="empty-tip">{{activeTab === 'created' ? '你还没有发起拼团，点击发起试试' : '你还没有加入拼团，去发起一个吧'}}</text>
    </view>

    <!-- 拼团列表 -->
    <scroll-view class="groups-scroll" scroll-y wx:else>
      <view
        class="group-card"
        wx:for="{{displayGroups}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onGroupTap"
      >
        <!-- 状态标签 -->
        <view class="group-status {{activeTab === 'created' ? 'leader' : 'joined'}}">
          <text class="status-text">
            {{activeTab === 'created' ? '我发起的' : '已加入'}}
          </text>
        </view>

        <!-- 团长信息 -->
        <view class="group-header">
          <view class="leader-info">
            <view class="leader-avatar-wrapper">
              <text class="leader-avatar">👤</text>
            </view>
            <view class="leader-meta">
              <text class="leader-name">{{item.leaderName}}</text>
              <text class="group-time">{{item.createTime}}</text>
            </view>
          </view>
          <view class="group-title">
            <text class="title-text">{{item.groupSize}}人拼团</text>
          </view>
        </view>

        <!-- 进度条 -->
        <view class="progress-section">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.progressPercent}}%"></view>
          </view>
          <text class="progress-text">{{item.currentSize}}/{{item.groupSize}}</text>
        </view>

        <!-- 成员列表 -->
        <view class="members-list">
          <view class="members-label">成员：</view>
          <view class="members-display">
            <view
              class="member-avatar"
              wx:for="{{item.members}}"
              wx:for-item="member"
              wx:key="userId"
            >
              <text>{{member.userName[0]}}</text>
            </view>
            <view class="member-empty" wx:if="{{item.currentSize < item.groupSize}}">
              <text class="plus-icon">+{{item.remainMembers}}</text>
            </view>
          </view>
        </view>

        <!-- 底部操作 -->
        <view class="group-footer">
          <view class="footer-left">
            <text class="reward-text">完成可得 <text class="reward-value">{{item.groupSize}}</text> 积分</text>
          </view>
          <view class="footer-right">
            <text class="status-badge {{item.status === 0 ? 'ongoing' : 'finished'}}">
              {{item.statusDesc}}
            </text>
          </view>
        </view>

      </view>

      <!-- 底部占位 -->
      <view class="bottom-placeholder"></view>
    </scroll-view>
  </view>

  <!-- 创建拼团弹窗 -->
  <view class="modal-mask" wx:if="{{showCreateModal}}" bindtap="onCloseCreateModal">
    <view class="modal-content" catchtap="preventTap">
      <view class="modal-header">
        <text class="modal-title">发起拼团</text>
        <view class="modal-close" bindtap="onCloseCreateModal">×</view>
      </view>

      <view class="modal-body">
        <view class="size-selector">
          <text class="selector-label">选择拼团人数：</text>
          <view class="size-buttons">
            <view
              class="size-btn {{selectedGroupSize === item ? 'active' : ''}}"
              wx:for="{{groupSizeOptions}}"
              wx:key="*this"
              data-size="{{item}}"
              bindtap="onSelectGroupSize"
            >
              <text class="size-number">{{item}}人</text>
              <text class="size-reward">+{{groupSizeRewardMap[item]}}积分</text>
            </view>
          </view>
        </view>

        <view class="modal-info">
          <text class="info-title">拼团说明：</text>
          <view class="info-list">
            <text class="info-item">• 人数满了即可获得积分奖励</text>
            <text class="info-item">• 每个拼团有效期12小时</text>
            <text class="info-item">• {{selectedGroupSize}}人团长完成可获得{{groupSizeRewardMap[selectedGroupSize]}}积分</text>
          </view>
        </view>
      </view>

      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="onCloseCreateModal">取消</view>
        <view class="modal-btn confirm {{creating ? 'loading' : ''}}" bindtap="onConfirmCreate">
          {{creating ? '发起中...' : '确认发起'}}
        </view>
      </view>
    </view>
  </view>
</view>
