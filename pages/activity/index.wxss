/* pages/activity/index.wxss - 活动中心 */
.activity-page {
  height: 100vh;
  background: linear-gradient(180deg, #f8f9fb 0%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.loading-wrapper, .error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .error-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.retry-btn {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: #667eea;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx 24rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.title-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.page-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.page-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

.header-btn {
  flex-shrink: 0;
  width: 120rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin: 0;
}

.header-btn::after {
  border: none;
}

.btn-icon {
  font-size: 24rpx;
}

.btn-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* 标签栏 */
.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.tab-item.active {
  border-bottom-color: #667eea;
}

.tab-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.tab-item.active .tab-label {
  color: #667eea;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 拼团列表 */
.groups-scroll {
  flex: 1;
  height: 0;
  padding: 20rpx 20rpx 24rpx 20rpx;
}

/* 拼团卡片 */
.group-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.12);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}


.group-card:active {
  transform: translateY(-4rpx) scale(1.01);
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.2);
}

/* 状态标签 */
.group-status {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 16rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  font-size: 18rpx;
}

.group-status.leader {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

.group-status.joined {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.15) 0%, rgba(133, 206, 97, 0.1) 100%);
  border: 1rpx solid rgba(82, 196, 26, 0.3);
}

.status-text {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.group-status.leader .status-text {
  color: #667eea;
}

.group-status.joined .status-text {
  color: #52c41a;
}

/* 团长信息 */
.group-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
  gap: 12rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.leader-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.leader-avatar-wrapper {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.leader-avatar {
  font-size: 24rpx;
}

.leader-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.leader-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.group-time {
  font-size: 20rpx;
  color: #999;
}

.group-title {
  display: flex;
  align-items: center;
}

.title-text {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 600;
  background: rgba(102, 126, 234, 0.1);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

/* 进度条 */
.progress-section {
  margin-bottom: 16rpx;
  padding: 12rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.progress-bar {
  height: 10rpx;
  background: #e8e8e8;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a 0%, #85ce61 100%);
  transition: width 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.3);
}

.progress-text {
  font-size: 18rpx;
  color: #999;
  text-align: right;
}

/* 成员列表 */
.members-list {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #f9f9fb 0%, #f5f7fa 100%);
  border-radius: 16rpx;
  border: 1rpx solid #f0f0f0;
}

.members-label {
  font-size: 20rpx;
  color: #666;
  font-weight: 600;
  flex-shrink: 0;
  letter-spacing: 0.5rpx;
}

.members-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  overflow: hidden;
}

.member-avatar {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 16rpx;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.member-empty {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
  border: 2rpx dashed #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plus-icon {
  font-size: 16rpx;
  color: #ccc;
  font-weight: 700;
}

/* 底部操作 */
.group-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 152, 0, 0.04) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 107, 107, 0.1);
}

.footer-left {
  font-size: 20rpx;
  color: #333;
  font-weight: 600;
}

.reward-text {
  color: #333;
  font-weight: 600;
}

.reward-value {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8c8c 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 800;
  font-size: 26rpx;
  margin: 0 6rpx;
}

.footer-right {
  display: flex;
  align-items: center;
}

.status-badge {
  font-size: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  color: #999;
  font-weight: 600;
}

.status-badge.ongoing {
  background: rgba(82, 196, 26, 0.15);
  color: #52c41a;
}

.status-badge.finished {
  background: rgba(200, 200, 200, 0.2);
  color: #999;
}

/* 加入按钮覆盖层 */
.join-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.join-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 底部占位 */
.bottom-placeholder {
  height: 20rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
}

.size-selector {
  margin-bottom: 32rpx;
}

.selector-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.size-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.size-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx 16rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.size-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.size-unit {
  font-size: 18rpx;
  color: #999;
  font-weight: 500;
}

.size-reward {
  font-size: 16rpx;
  color: #52c41a;
  font-weight: 600;
  margin-top: 4rpx;
}

.size-btn.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-color: #667eea;
}

.size-btn.active .size-number {
  color: #667eea;
}

.size-btn.active .size-unit {
  color: #667eea;
}

.size-btn.active .size-reward {
  color: #ff6b6b;
}

.modal-info {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.info-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item {
  font-size: 20rpx;
  color: #666;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f5f5f5;
}

.modal-btn.confirm {
  color: #667eea;
}

.modal-btn.confirm.loading {
  color: #999;
}

.modal-btn:active {
  background: #f9f9f9;
}
