/* pages/agreement/index.wxss */
.agreement-page {
  height: 100vh;
  background-color: #ffffff;
}

.content {
  padding: 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.4;
}

.subtitle {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.paragraph {
  display: block;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  margin-bottom: 16rpx;
  text-align: justify;
}

.paragraph.bold {
  font-weight: 600;
  color: #334155;
  margin-top: 24rpx;
}

.paragraph.list-item {
  padding-left: 16rpx;
  margin-bottom: 12rpx;
}

.update-time {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

.footer-space {
  height: 60rpx;
}
