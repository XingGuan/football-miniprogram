<!-- pages/history/index.wxml -->
<view class="history-page">
  <!-- 统计信息 -->
  <view class="stats-bar" wx:if="{{list.length > 0}}">
    <text class="stats-text">共 {{total}} 条记录</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading && list.length === 0}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 未登录 -->
  <empty-state
    wx:elif="{{error === '请先登录'}}"
    type="empty"
    title="未登录"
    description="登录后查看历史记录"
    button-text="去登录"
    bind:buttonTap="onLogin"
  />

  <!-- 错误状态 -->
  <empty-state
    wx:elif="{{error}}"
    type="error"
    title="加载失败"
    description="{{error}}"
    button-text="重试"
    bind:buttonTap="onRetry"
  />

  <!-- 空状态 -->
  <empty-state
    wx:elif="{{!loading && list.length === 0}}"
    type="empty"
    title="暂无记录"
    description="你还没有任何分析记录"
  />

  <!-- 历史列表 -->
  <view class="history-list" wx:else>
    <history-card
      wx:for="{{list}}"
      wx:key="id"
      record="{{item}}"
      bind:tap="onItemTap"
      bind:delete="onDelete"
    />

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <view class="loading-spinner small" wx:if="{{loading}}"></view>
      <text class="load-more-text" wx:else>上拉加载更多</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:else>
      <text class="no-more-text">没有更多了</text>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
