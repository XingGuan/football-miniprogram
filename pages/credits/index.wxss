/* pages/credits/index.wxss */
.credits-page {
  min-height: 100vh;
  background: #f8f9fc;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 24rpx 50rpx;
  color: #fff;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
}

.header-desc {
  font-size: 28rpx;
  opacity: 0.95;
  font-weight: 500;
}

/* 套餐选择 */
.packages-section {
  padding: 32rpx 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

.packages-container {
  display: flex;
  gap: 16rpx;
}

.package-card {
  flex: 1;
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 20rpx 32rpx;
  text-align: center;
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  min-height: 320rpx;
}

.badges-container {
  height: 32rpx;
  position: relative;
  margin-bottom: 12rpx;
}

.package-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.02) 0%, rgba(118, 75, 162, 0.02) 100%);
  pointer-events: none;
}

.package-card:active {
  transform: translateY(-8rpx);
}

.package-card.selected {
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.25);
  transform: scale(1.02);
}

.package-card.popular {
  transform: scale(1.08);
  background: linear-gradient(135deg, #fff 0%, #f8f9fc 100%);
}

.package-card.popular::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: conic-gradient(
    from 0deg,
    rgba(102, 126, 234, 0.1) 0deg,
    transparent 120deg,
    rgba(102, 126, 234, 0.1) 240deg
  );
  animation: rotate 8s linear infinite;
  pointer-events: none;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.package-card.popular.selected {
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.3);
}

.popular-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 106, 136, 0.3);
  z-index: 2;
}

.first-price-badge {
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  z-index: 2;
}

.badge-placeholder {
  height: 32rpx;
}

.package-icon {
  font-size: 60rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.package-points-large {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 70rpx;
  position: relative;
  z-index: 1;
}

.points-value-large {
  font-size: 56rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1;
}

.points-unit-large {
  font-size: 26rpx;
  color: #999;
  font-weight: 600;
  line-height: 1;
}

.package-price-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  position: relative;
  z-index: 1;
  align-items: center;
  height: 80rpx;
  justify-content: center;
}

.original-price {
  font-size: 24rpx;
  color: #ccc;
  text-decoration: line-through;
  height: 30rpx;
  line-height: 30rpx;
}

.current-price {
  font-size: 48rpx;
  font-weight: 900;
  color: #333;
  height: 50rpx;
  line-height: 50rpx;
}

.current-price.discount {
  color: #ff6a88;
}

.price-desc {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 600;
  height: 32rpx;
}

.check-mark {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  z-index: 2;
}

/* 功能说明 */
.features-section {
  padding: 0 24rpx 40rpx;
}

.features-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.feature-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.feature-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.feature-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 联系方式 */
.contact-section {
  padding: 0 24rpx 40rpx;
}

.steps-container {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.step-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  align-items: flex-start;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-number {
  min-width: 40rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  flex-shrink: 0;
}

.step-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 二维码 */
.qrcode-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.qrcode-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.qrcode-image {
  width: 300rpx;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.qrcode-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 客服按钮 */
.contact-buttons {
  display: flex;
  gap: 16rpx;
}

.contact-btn {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.contact-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  animation: slideUp 0.3s ease;
  max-height: 90vh;
  overflow-y: auto;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.label {
  min-width: 80rpx;
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
}

.value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.input-with-btn {
  flex: 1;
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.modal-input {
  flex: 1;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 26rpx;
}

.copy-btn {
  background: #667eea;
  color: #fff;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  white-space: nowrap;
}

.modal-tips {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx 24rpx;
  border-top: 1rpx solid #e0e0e0;
}

.modal-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #333;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.modal-btn.confirm::after {
  border: none;
}

/* 安全区域 */
.safe-area-bottom {
  height: 100rpx;
}
