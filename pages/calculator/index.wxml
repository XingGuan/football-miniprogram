<!-- pages/calculator/index.wxml -->
<view class="calculator-page">
  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrapper" wx:elif="{{error}}">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="onRetry">重试</view>
  </view>

  <!-- 主内容 -->
  <view class="main-content" wx:else>
    <!-- 顶部Tab切换 -->
    <view class="tab-header">
      <view class="tab-item {{currentTab === 'play' ? 'active' : ''}}" bindtap="onSwitchTab" data-tab="play">
        <text class="tab-text">模拟投注</text>
      </view>
      <view class="tab-item {{currentTab === 'records' ? 'active' : ''}}" bindtap="onSwitchTab" data-tab="records">
        <text class="tab-text">我的记录</text>
        <text class="record-badge" wx:if="{{records.length > 0}}">{{records.length}}</text>
      </view>
    </view>

    <!-- 模拟投注内容 -->
    <view class="tab-content" wx:if="{{currentTab === 'play'}}">
    <!-- 比赛列表 -->
    <scroll-view class="match-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="match-card" wx:for="{{matches}}" wx:key="matchId">
        <!-- 比赛信息头 -->
        <view class="card-header">
          <text class="match-num">{{item.matchNumStr}}</text>
          <text class="league-name">{{item.leagueAbbName}}</text>
          <text class="match-time">{{item.matchTime}}</text>
          <!-- 单关标记 -->
          <text class="single-tag" wx:if="{{item.bettingSingle == 1}}">单</text>
        </view>

        <!-- 对阵信息 -->
        <view class="team-row">
          <text class="team-name home">{{item.homeTeamAbbName}}</text>
          <text class="vs-text">VS</text>
          <text class="team-name away">{{item.awayTeamAbbName}}</text>
        </view>

        <!-- 赔率区域 -->
        <view class="odds-wrapper">
          <view class="odds-left">
            <!-- 胜平负 -->
            <view class="odds-section">
              <text class="section-title">胜平负</text>
              <view class="odds-row">
                <view class="odds-item {{selectedMap[item.matchId + '_had_H'] ? 'active' : ''}}" data-matchid="{{item.matchId}}" data-type="had" data-value="H" data-odds="{{item.hadH}}" bindtap="onSelectOption">
                  <text class="odds-label">主胜</text>
                  <text class="odds-value">{{item.hadH}}</text>
                </view>
                <view class="odds-item {{selectedMap[item.matchId + '_had_D'] ? 'active' : ''}}" data-matchid="{{item.matchId}}" data-type="had" data-value="D" data-odds="{{item.hadD}}" bindtap="onSelectOption">
                  <text class="odds-label">平局</text>
                  <text class="odds-value">{{item.hadD}}</text>
                </view>
                <view class="odds-item {{selectedMap[item.matchId + '_had_A'] ? 'active' : ''}}" data-matchid="{{item.matchId}}" data-type="had" data-value="A" data-odds="{{item.hadA}}" bindtap="onSelectOption">
                  <text class="odds-label">客胜</text>
                  <text class="odds-value">{{item.hadA}}</text>
                </view>
              </view>
            </view>

            <!-- 让球胜平负 -->
            <view class="odds-section last">
              <text class="section-title">让球({{item.hhadGoalLine}})</text>
              <view class="odds-row">
                <view class="odds-item {{selectedMap[item.matchId + '_hhad_H'] ? 'active' : ''}}" data-matchid="{{item.matchId}}" data-type="hhad" data-value="H" data-odds="{{item.hhadH}}" bindtap="onSelectOption">
                  <text class="odds-label">主胜</text>
                  <text class="odds-value">{{item.hhadH}}</text>
                </view>
                <view class="odds-item {{selectedMap[item.matchId + '_hhad_D'] ? 'active' : ''}}" data-matchid="{{item.matchId}}" data-type="hhad" data-value="D" data-odds="{{item.hhadD}}" bindtap="onSelectOption">
                  <text class="odds-label">平局</text>
                  <text class="odds-value">{{item.hhadD}}</text>
                </view>
                <view class="odds-item {{selectedMap[item.matchId + '_hhad_A'] ? 'active' : ''}}" data-matchid="{{item.matchId}}" data-type="hhad" data-value="A" data-odds="{{item.hhadA}}" bindtap="onSelectOption">
                  <text class="odds-label">客胜</text>
                  <text class="odds-value">{{item.hhadA}}</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 右侧更多玩法 -->
          <view class="card-right" data-match="{{item}}" bindtap="onMorePlays">
            <text class="more-text">更</text>
            <text class="more-text">多</text>
          </view>
        </view>

        <!-- 选中标记 -->
        <view class="selected-badge" wx:if="{{selections[item.matchId].length > 0}}">
          已选{{selections[item.matchId].length}}项
        </view>
      </view>

      <!-- 底部占位 -->
      <view class="bottom-placeholder"></view>
    </scroll-view>
    </view>

    <!-- 我的记录内容 -->
    <view class="tab-content records-content" wx:if="{{currentTab === 'records'}}">
      <view class="records-loading" wx:if="{{recordsLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
      <view class="records-empty" wx:elif="{{records.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无记录</text>
        <text class="empty-tip">保存模拟投注后记录将显示在这里</text>
      </view>
      <scroll-view class="records-scroll" scroll-y wx:else>
        <view class="record-swipe-wrapper" wx:for="{{records}}" wx:key="id">
          <view class="record-swipe-inner {{item.swiped ? 'swiped' : ''}}"
                data-index="{{index}}"
                bindtouchstart="onTouchStart"
                bindtouchmove="onTouchMove"
                bindtouchend="onTouchEnd">
            <view class="record-card" bindtap="onRecordTap" data-record="{{item}}">
              <view class="record-header">
                <text class="record-time">{{item.createTimeStr}}</text>
                <text class="record-status {{item.status === 1 ? 'win' : item.status === 2 ? 'lose' : ''}}">
                  {{item.statusDesc}}
                </text>
              </view>
              <view class="record-info">
                <text class="record-matches">{{item.matchCount}}场比赛</text>
                <text class="record-pass">{{item.passTypesStr}}</text>
              </view>
              <view class="record-footer">
                <text class="record-amount">{{item.totalBets}}注 × {{item.multiple}}倍 = {{item.totalAmount}}元</text>
                <text class="record-bonus" wx:if="{{item.bonus > 0}}">奖金: {{item.bonus}}元</text>
              </view>
              <view class="record-arrow">›</view>
            </view>
            <view class="record-delete-btn" catchtap="onDeleteRecord" data-id="{{item.id}}" data-index="{{index}}">
              <text class="delete-text">删除</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 底部操作栏 - 仅在模拟投注tab显示 -->
    <view class="bottom-bar" wx:if="{{currentTab === 'play'}}">
      <!-- 过关方式选择 -->
      <view class="pass-type-row">
        <view class="pass-btn {{selectedPassTypes.indexOf(item.value) > -1 ? 'active' : ''}} {{item.value == 'single' ? (singleAvailable ? '' : 'disabled') : (selectedCount < item.min ? 'disabled' : '')}}" wx:for="{{passTypes}}" wx:key="value" data-value="{{item.value}}" data-min="{{item.min}}" bindtap="onSelectPassType">
          {{item.label}}
        </view>
      </view>

      <!-- 倍数和金额 -->
      <view class="amount-row">
        <view class="multiple-box">
          <text class="label">倍数</text>
          <view class="stepper">
            <view class="stepper-btn" bindtap="onMultipleMinus">-</view>
            <input class="stepper-input" type="number" value="{{multiple}}" bindinput="onMultipleChange" />
            <view class="stepper-btn" bindtap="onMultiplePlus">+</view>
          </view>
        </view>
        <view class="amount-info">
          <text class="amount-label">{{totalBets}}注 / {{totalAmount}}元</text>
          <text class="bonus-text" wx:if="{{totalBets > 0}}">预计奖金: {{minBonus}}-{{maxBonus}}元</text>
        </view>
        <view class="submit-btn {{totalBets > 0 ? '' : 'disabled'}}" bindtap="onSubmit">保存</view>
      </view>
    </view>
  </view>

  <!-- 更多玩法弹窗 -->
  <view class="popup-mask" wx:if="{{showMorePlays}}" bindtap="onCloseMorePlays">
    <view class="popup-content" catchtap="onPreventTap">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <text class="popup-title" wx:if="{{currentMatch}}">{{currentMatch.homeTeamAbbName}} VS {{currentMatch.awayTeamAbbName}}</text>
        <view class="popup-close" bindtap="onCloseMorePlays">×</view>
      </view>

      <!-- 弹窗内容 -->
      <scroll-view class="popup-body" scroll-y wx:if="{{currentMatch}}">
        <!-- 比分 -->
        <view class="play-section">
          <text class="play-title">比分</text>
          <!-- 主胜 -->
          <view class="score-group">
            <text class="group-label">主胜</text>
            <view class="score-grid">
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_1:0'] ? 'active' : ''}}" data-score="1:0" data-odds="{{currentMatch.crsS01s00}}" bindtap="onSelectScore">
                <text class="s-label">1:0</text><text class="s-odds">{{currentMatch.crsS01s00}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_2:0'] ? 'active' : ''}}" data-score="2:0" data-odds="{{currentMatch.crsS02s00}}" bindtap="onSelectScore">
                <text class="s-label">2:0</text><text class="s-odds">{{currentMatch.crsS02s00}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_2:1'] ? 'active' : ''}}" data-score="2:1" data-odds="{{currentMatch.crsS02s01}}" bindtap="onSelectScore">
                <text class="s-label">2:1</text><text class="s-odds">{{currentMatch.crsS02s01}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_3:0'] ? 'active' : ''}}" data-score="3:0" data-odds="{{currentMatch.crsS03s00}}" bindtap="onSelectScore">
                <text class="s-label">3:0</text><text class="s-odds">{{currentMatch.crsS03s00}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_3:1'] ? 'active' : ''}}" data-score="3:1" data-odds="{{currentMatch.crsS03s01}}" bindtap="onSelectScore">
                <text class="s-label">3:1</text><text class="s-odds">{{currentMatch.crsS03s01}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_3:2'] ? 'active' : ''}}" data-score="3:2" data-odds="{{currentMatch.crsS03s02}}" bindtap="onSelectScore">
                <text class="s-label">3:2</text><text class="s-odds">{{currentMatch.crsS03s02}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_4:0'] ? 'active' : ''}}" data-score="4:0" data-odds="{{currentMatch.crsS04s00}}" bindtap="onSelectScore">
                <text class="s-label">4:0</text><text class="s-odds">{{currentMatch.crsS04s00}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_胜其他'] ? 'active' : ''}}" data-score="胜其他" data-odds="{{currentMatch.crsS1sh}}" bindtap="onSelectScore">
                <text class="s-label">胜其他</text><text class="s-odds">{{currentMatch.crsS1sh}}</text>
              </view>
            </view>
          </view>
          <!-- 平局 -->
          <view class="score-group">
            <text class="group-label">平局</text>
            <view class="score-grid">
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_0:0'] ? 'active' : ''}}" data-score="0:0" data-odds="{{currentMatch.crsS00s00}}" bindtap="onSelectScore">
                <text class="s-label">0:0</text><text class="s-odds">{{currentMatch.crsS00s00}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_1:1'] ? 'active' : ''}}" data-score="1:1" data-odds="{{currentMatch.crsS01s01}}" bindtap="onSelectScore">
                <text class="s-label">1:1</text><text class="s-odds">{{currentMatch.crsS01s01}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_2:2'] ? 'active' : ''}}" data-score="2:2" data-odds="{{currentMatch.crsS02s02}}" bindtap="onSelectScore">
                <text class="s-label">2:2</text><text class="s-odds">{{currentMatch.crsS02s02}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_3:3'] ? 'active' : ''}}" data-score="3:3" data-odds="{{currentMatch.crsS03s03}}" bindtap="onSelectScore">
                <text class="s-label">3:3</text><text class="s-odds">{{currentMatch.crsS03s03}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_平其他'] ? 'active' : ''}}" data-score="平其他" data-odds="{{currentMatch.crsS1sd}}" bindtap="onSelectScore">
                <text class="s-label">平其他</text><text class="s-odds">{{currentMatch.crsS1sd}}</text>
              </view>
            </view>
          </view>
          <!-- 客胜 -->
          <view class="score-group">
            <text class="group-label">客胜</text>
            <view class="score-grid">
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_0:1'] ? 'active' : ''}}" data-score="0:1" data-odds="{{currentMatch.crsS00s01}}" bindtap="onSelectScore">
                <text class="s-label">0:1</text><text class="s-odds">{{currentMatch.crsS00s01}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_0:2'] ? 'active' : ''}}" data-score="0:2" data-odds="{{currentMatch.crsS00s02}}" bindtap="onSelectScore">
                <text class="s-label">0:2</text><text class="s-odds">{{currentMatch.crsS00s02}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_1:2'] ? 'active' : ''}}" data-score="1:2" data-odds="{{currentMatch.crsS01s02}}" bindtap="onSelectScore">
                <text class="s-label">1:2</text><text class="s-odds">{{currentMatch.crsS01s02}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_0:3'] ? 'active' : ''}}" data-score="0:3" data-odds="{{currentMatch.crsS00s03}}" bindtap="onSelectScore">
                <text class="s-label">0:3</text><text class="s-odds">{{currentMatch.crsS00s03}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_1:3'] ? 'active' : ''}}" data-score="1:3" data-odds="{{currentMatch.crsS01s03}}" bindtap="onSelectScore">
                <text class="s-label">1:3</text><text class="s-odds">{{currentMatch.crsS01s03}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_2:3'] ? 'active' : ''}}" data-score="2:3" data-odds="{{currentMatch.crsS02s03}}" bindtap="onSelectScore">
                <text class="s-label">2:3</text><text class="s-odds">{{currentMatch.crsS02s03}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_0:4'] ? 'active' : ''}}" data-score="0:4" data-odds="{{currentMatch.crsS00s04}}" bindtap="onSelectScore">
                <text class="s-label">0:4</text><text class="s-odds">{{currentMatch.crsS00s04}}</text>
              </view>
              <view class="score-item {{selectedMap[currentMatch.matchId + '_crs_负其他'] ? 'active' : ''}}" data-score="负其他" data-odds="{{currentMatch.crsS1sa}}" bindtap="onSelectScore">
                <text class="s-label">负其他</text><text class="s-odds">{{currentMatch.crsS1sa}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 总进球 -->
        <view class="play-section">
          <text class="play-title">总进球</text>
          <view class="goal-grid">
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_0'] ? 'active' : ''}}" data-goal="0" data-odds="{{currentMatch.ttgS0}}" bindtap="onSelectGoal">
              <text class="g-label">0球</text><text class="g-odds">{{currentMatch.ttgS0}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_1'] ? 'active' : ''}}" data-goal="1" data-odds="{{currentMatch.ttgS1}}" bindtap="onSelectGoal">
              <text class="g-label">1球</text><text class="g-odds">{{currentMatch.ttgS1}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_2'] ? 'active' : ''}}" data-goal="2" data-odds="{{currentMatch.ttgS2}}" bindtap="onSelectGoal">
              <text class="g-label">2球</text><text class="g-odds">{{currentMatch.ttgS2}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_3'] ? 'active' : ''}}" data-goal="3" data-odds="{{currentMatch.ttgS3}}" bindtap="onSelectGoal">
              <text class="g-label">3球</text><text class="g-odds">{{currentMatch.ttgS3}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_4'] ? 'active' : ''}}" data-goal="4" data-odds="{{currentMatch.ttgS4}}" bindtap="onSelectGoal">
              <text class="g-label">4球</text><text class="g-odds">{{currentMatch.ttgS4}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_5'] ? 'active' : ''}}" data-goal="5" data-odds="{{currentMatch.ttgS5}}" bindtap="onSelectGoal">
              <text class="g-label">5球</text><text class="g-odds">{{currentMatch.ttgS5}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_6'] ? 'active' : ''}}" data-goal="6" data-odds="{{currentMatch.ttgS6}}" bindtap="onSelectGoal">
              <text class="g-label">6球</text><text class="g-odds">{{currentMatch.ttgS6}}</text>
            </view>
            <view class="goal-item {{selectedMap[currentMatch.matchId + '_ttg_7'] ? 'active' : ''}}" data-goal="7" data-odds="{{currentMatch.ttgS7}}" bindtap="onSelectGoal">
              <text class="g-label">7+球</text><text class="g-odds">{{currentMatch.ttgS7}}</text>
            </view>
          </view>
        </view>

        <!-- 半全场 -->
        <view class="play-section">
          <text class="play-title">半全场</text>
          <view class="hafu-grid">
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_HH'] ? 'active' : ''}}" data-hafu="HH" data-odds="{{currentMatch.hafuHh}}" bindtap="onSelectHafu">
              <text class="h-label">胜-胜</text><text class="h-odds">{{currentMatch.hafuHh}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_HD'] ? 'active' : ''}}" data-hafu="HD" data-odds="{{currentMatch.hafuHd}}" bindtap="onSelectHafu">
              <text class="h-label">胜-平</text><text class="h-odds">{{currentMatch.hafuHd}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_HA'] ? 'active' : ''}}" data-hafu="HA" data-odds="{{currentMatch.hafuHa}}" bindtap="onSelectHafu">
              <text class="h-label">胜-负</text><text class="h-odds">{{currentMatch.hafuHa}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_DH'] ? 'active' : ''}}" data-hafu="DH" data-odds="{{currentMatch.hafuDh}}" bindtap="onSelectHafu">
              <text class="h-label">平-胜</text><text class="h-odds">{{currentMatch.hafuDh}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_DD'] ? 'active' : ''}}" data-hafu="DD" data-odds="{{currentMatch.hafuDd}}" bindtap="onSelectHafu">
              <text class="h-label">平-平</text><text class="h-odds">{{currentMatch.hafuDd}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_DA'] ? 'active' : ''}}" data-hafu="DA" data-odds="{{currentMatch.hafuDa}}" bindtap="onSelectHafu">
              <text class="h-label">平-负</text><text class="h-odds">{{currentMatch.hafuDa}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_AH'] ? 'active' : ''}}" data-hafu="AH" data-odds="{{currentMatch.hafuAh}}" bindtap="onSelectHafu">
              <text class="h-label">负-胜</text><text class="h-odds">{{currentMatch.hafuAh}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_AD'] ? 'active' : ''}}" data-hafu="AD" data-odds="{{currentMatch.hafuAd}}" bindtap="onSelectHafu">
              <text class="h-label">负-平</text><text class="h-odds">{{currentMatch.hafuAd}}</text>
            </view>
            <view class="hafu-item {{selectedMap[currentMatch.matchId + '_hafu_AA'] ? 'active' : ''}}" data-hafu="AA" data-odds="{{currentMatch.hafuAa}}" bindtap="onSelectHafu">
              <text class="h-label">负-负</text><text class="h-odds">{{currentMatch.hafuAa}}</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 弹窗底部 -->
      <view class="popup-footer">
        <view class="popup-btn" bindtap="onCloseMorePlays">确定</view>
      </view>
    </view>
  </view>
</view>
