<!-- pages/index/index.wxml -->
<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 错误状态 -->
  <empty-state
    wx:elif="{{error}}"
    type="error"
    title="加载失败"
    description="{{error}}"
    button-text="重试"
    bind:buttonTap="onRetry"
  />

  <!-- 空状态 -->
  <empty-state
    wx:elif="{{!loading && matches.length === 0}}"
    type="empty"
    title="暂无比赛"
    description="当前日期没有比赛数据"
  />

  <!-- 比赛列表 -->
  <view class="match-list" wx:else>
    <view class="weekday-group" wx:for="{{groupedMatches}}" wx:key="league" wx:for-index="groupIndex">
      <view class="weekday-header" data-index="{{groupIndex}}" bindtap="onToggleGroup">
        <view class="weekday-left">
          <text class="weekday-name">{{item.league}}</text>
          <text class="match-count">{{item.matches.length}}场</text>
        </view>
        <view class="weekday-right">
          <text class="toggle-icon {{collapsedGroups[groupIndex] ? 'collapsed' : ''}}"></text>
        </view>
      </view>

      <view class="match-items {{collapsedGroups[groupIndex] ? 'hidden' : ''}}">
        <match-card
          wx:for="{{item.matches}}"
          wx:for-item="match"
          wx:key="id"
          match="{{match}}"
          bind:matchtap="onMatchTap"
          bind:analyze="onAnalyze"
        />
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
