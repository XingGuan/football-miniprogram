/* pages/vip/index.wxss */
.vip-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fc 0%, #eef1f8 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 头部区域 ========== */
.header {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  padding: 80rpx 32rpx 60rpx;
  overflow: hidden;
}

.header-bg-decoration {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.header-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.header-bg-circle.circle-1 {
  width: 200rpx;
  height: 200rpx;
  bottom: -60rpx;
  left: -40rpx;
}

.header-bg-circle.circle-2 {
  width: 120rpx;
  height: 120rpx;
  top: 40rpx;
  right: 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* ========== 权益区域 ========== */
.benefits-section {
  padding: 32rpx 24rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}

.benefits-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.benefits-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
}

.benefits-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.3) 0%, transparent 100%);
}

.benefits-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.benefit-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.08);
  transition: all 0.3s ease;
}

.benefit-item:active {
  transform: scale(0.98);
}

.benefit-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.benefit-icon {
  font-size: 32rpx;
}

.benefit-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.benefit-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.benefit-desc {
  font-size: 20rpx;
  color: #999;
  display: block;
}

/* ========== 会员状态卡片 ========== */
.status-section {
  padding: 0 24rpx 24rpx;
}

.vip-status-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffb347 50%, #ff8c00 100%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.35);
}

.status-bg-glow {
  position: absolute;
  top: -60%;
  left: 50%;
  transform: translateX(-50%);
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

/* 会员钻石图标 */
.status-crown-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.status-crown-diamond {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.status-crown-diamond::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 14rpx solid #fff;
}

.status-crown-diamond::after {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 26rpx solid #fff;
}

.status-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
  z-index: 1;
  margin-bottom: 20rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.status-expire {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(0, 0, 0, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-renew-btn {
  position: relative;
  z-index: 1;
  background: #fff;
  padding: 16rpx 48rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.status-renew-btn text {
  font-size: 28rpx;
  color: #ff8c00;
  font-weight: bold;
}

.status-renew-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ========== 套餐选择 ========== */
.packages-section {
  padding: 32rpx 24rpx;
}

.section-header {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: #ff6a88;
  margin-top: 8rpx;
  font-weight: 500;
}

.packages-container {
  display: flex;
  gap: 20rpx;
}

.package-card {
  flex: 1;
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  border: 3rpx solid transparent;
  overflow: hidden;
}

.package-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  opacity: 0;
  transition: opacity 0.3s;
}

.package-card:active {
  transform: scale(0.98);
}

.package-card.selected {
  border-color: #667eea;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.25);
}

.package-card.selected::before {
  opacity: 1;
}

.package-card.popular {
  transform: scale(1.05);
  border-color: #ff6a88;
  box-shadow: 0 12rpx 40rpx rgba(255, 106, 136, 0.2);
}

.package-card.popular::before {
  background: linear-gradient(90deg, #ff9a56 0%, #ff6a88 100%);
  opacity: 1;
}

.package-card.popular.selected {
  box-shadow: 0 16rpx 48rpx rgba(255, 106, 136, 0.3);
}

/* 推荐丝带 */
.popular-ribbon {
  position: absolute;
  top: 20rpx;
  right: -30rpx;
  background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%);
  color: #fff;
  padding: 6rpx 40rpx;
  font-size: 20rpx;
  font-weight: bold;
  transform: rotate(45deg);
  box-shadow: 0 4rpx 12rpx rgba(255, 106, 136, 0.3);
  z-index: 3;
}

.package-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.package-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.best-value-tag {
  background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.best-value-tag text {
  font-size: 18rpx;
  color: #fff;
  font-weight: bold;
}

.package-icon-box {
  margin-bottom: 12rpx;
}

.package-emoji {
  font-size: 56rpx;
}

.package-duration {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 16rpx;
}

.duration-num {
  font-size: 52rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1;
}

.popular .duration-num {
  background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.duration-unit {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.package-price {
  margin-bottom: 12rpx;
}

.price-original {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  color: #bbb;
  text-decoration: line-through;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.original-num {
  font-size: 24rpx;
}

.price-current {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.currency {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6a88;
}

.price-num {
  font-size: 56rpx;
  font-weight: 900;
  color: #ff6a88;
  line-height: 1;
}

.package-save {
  display: inline-block;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.package-save text {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 600;
}

.package-save.hot {
  background: linear-gradient(135deg, rgba(255, 154, 86, 0.15) 0%, rgba(255, 106, 136, 0.15) 100%);
}

.package-save.hot text {
  color: #ff6a88;
}

.package-avg {
  margin-top: 4rpx;
}

.package-avg text {
  font-size: 20rpx;
  color: #999;
}

.check-indicator {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.popular .check-indicator {
  background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 106, 136, 0.3);
}

.check-indicator text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 卡片光效 */
.card-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.2),
    transparent
  );
  animation: shine 3s infinite;
}

@keyframes shine {
  0% {
    left: -100%;
  }
  50%, 100% {
    left: 150%;
  }
}

/* ========== 购买流程 ========== */
.purchase-section {
  padding: 32rpx 24rpx;
}

.purchase-steps {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  position: relative;
  padding-bottom: 20rpx;
}

.step-item:last-child {
  padding-bottom: 0;
}

.step-number {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.step-number text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.step-line {
  position: absolute;
  left: 21rpx;
  top: 44rpx;
  width: 2rpx;
  height: calc(100% - 24rpx);
  background: linear-gradient(180deg, #667eea 0%, rgba(102, 126, 234, 0.2) 100%);
}

.step-content {
  flex: 1;
  padding-top: 4rpx;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* ========== 二维码区域 ========== */
.qrcode-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.qrcode-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.qrcode-dot {
  width: 8rpx;
  height: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
}

.qrcode-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.qrcode-wrapper {
  display: inline-block;
  padding: 16rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.qrcode-image {
  width: 280rpx;
  height: 280rpx;
  border-radius: 12rpx;
}

.qrcode-tip {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* ========== 联系客服按钮 ========== */
.contact-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.contact-btn::after {
  border: none;
}

.contact-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

.btn-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
}

/* ========== FAQ区域 ========== */
.faq-section {
  padding: 32rpx 24rpx;
}

.faq-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.faq-item {
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s ease;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-item.active {
  background: #f8f9fc;
}

.faq-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 16rpx;
}

.faq-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.faq-icon {
  font-size: 24rpx;
}

.faq-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.faq-toggle {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.faq-toggle text {
  font-size: 32rpx;
  color: #667eea;
  font-weight: 300;
}

.faq-toggle.open {
  transform: rotate(90deg);
}

.faq-content {
  padding: 0 24rpx 24rpx 84rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.faq-content text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== 底部安全区域 ========== */
.safe-area-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
