/* pages/calculator-detail/index.wxss */
.detail-page {
  min-height: 100vh;
  background: #f5f7fa;
}

.loading-wrapper, .error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .error-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.detail-content {
  height: 100vh;
  padding: 16rpx;
  box-sizing: border-box;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.status-card.win {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8c8c 100%);
}

.status-card.lose {
  background: linear-gradient(135deg, #d9d9d9 0%, #e8e8e8 100%);
}

.status-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.scheme-no {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.status-card.lose .status-text {
  color: #999;
  text-shadow: none;
}

.status-card.lose .scheme-no {
  color: rgba(100, 100, 100, 0.8);
}

/* 信息卡片 */
.info-card, .matches-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.info-value.highlight {
  color: #667eea;
}

.info-value.amount {
  color: #ff6b6b;
}

.bonus-row, .time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 16rpx;
}

.bonus-label, .time-label {
  font-size: 24rpx;
  color: #999;
}

.bonus-value {
  font-size: 28rpx;
  color: #52c41a;
  font-weight: 600;
}

.bonus-value.win {
  color: #ff6b6b;
}

.bonus-value.lose {
  color: #999;
}

.time-value {
  font-size: 24rpx;
  color: #666;
}

/* 比赛列表 */
.match-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.match-item:last-child {
  border-bottom: none;
}

.match-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.match-num {
  font-size: 22rpx;
  color: #fff;
  background: #667eea;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

.match-time {
  font-size: 22rpx;
  color: #999;
}

.match-teams {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.team {
  flex: 1;
}

.team.away {
  text-align: right;
}

.team-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.vs-box {
  padding: 0 20rpx;
}

.vs {
  font-size: 24rpx;
  color: #ccc;
  font-weight: 500;
}

/* 开奖结果 */
.option-result {
  width: 110rpx;
  padding: 10rpx 12rpx;
  background: #f8f9fc;
  border-radius: 8rpx;
  border-left: 3rpx solid #667eea;
  text-align: center;
  transition: all 0.2s ease;
}

/* 中奖 - 红色 */
.option-result.hit {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.12) 0%, rgba(255, 140, 140, 0.08) 100%);
  border-left-color: #ff6b6b;
}

/* 待开奖 - 绿色 */
.option-result.pending {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.12) 0%, rgba(115, 209, 61, 0.08) 100%);
  border-left-color: #52c41a;
}

/* 未中奖 - 灰色 */
.option-result.miss {
  background: rgba(200, 200, 200, 0.08);
  border-left-color: #d9d9d9;
}

.result-value {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.option-result.hit .result-value {
  color: #ff6b6b;
  font-weight: 600;
}

.option-result.pending .result-value {
  color: #52c41a;
  font-weight: 600;
}

.option-result.miss .result-value {
  color: #999;
  font-weight: 400;
}

.match-options {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.option-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 150rpx;
  flex: 1;
  border-radius: 8rpx;
  border: none;
  transition: all 0.2s ease;
}

/* 未中奖 - 灰色背景 */
.option-item.miss .opt-content {
  background: linear-gradient(135deg, #bdbdbd 0%, #d0d0d0 100%);
}

.opt-content {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, #c41d1d 0%, #d32f2f 100%);
  border-radius: 8rpx;
  width: 100rpx;
}

.opt-type {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  min-width: 120rpx;
}

.opt-highlight {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.opt-value {
  font-size: 32rpx;
  color: #fff;
  font-weight: 900;
}

.opt-odds {
  font-size: 32rpx;
  color: #fff;
  font-weight: 900;
  white-space: nowrap;
}

.hit-icon {
  color: #fff;
  font-weight: 700;
  font-size: 22rpx;
}

.miss-icon {
  color: rgba(255, 255, 255, 0.7);
  font-weight: 700;
  font-size: 22rpx;
}

.bottom-placeholder {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* 底部分享栏 */
.bottom-share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  display: flex;
  gap: 12rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
}

.share-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}
