/* pages/calculator-detail/index.wxss */
.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fb 0%, #f5f7fa 100%);
}

.loading-wrapper, .error-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .error-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.detail-content {
  min-height: 100vh;
  padding: 20rpx 16rpx 120rpx 16rpx;
  box-sizing: border-box;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.15);
}

.status-card.win {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8c8c 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.15);
}

.status-card.lose {
  background: linear-gradient(135deg, #d9d9d9 0%, #e8e8e8 100%);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.status-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  display: block;
}

.status-text {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.scheme-no {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.status-card.lose .status-text {
  color: #999;
}

.status-card.lose .scheme-no {
  color: rgba(100, 100, 100, 0.8);
}

/* 信息卡片 */
.info-card, .matches-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #f0f0f0;
  letter-spacing: 0.5rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: #f8f9fb;
  border-radius: 12rpx;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 700;
  line-height: 1.2;
}

.info-value.highlight {
  color: #667eea;
}

.info-value.amount {
  color: #ff6b6b;
}

.bonus-row, .time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 18rpx;
}

.bonus-row:first-child, .time-row:first-child {
  border-top: none;
  margin-top: 0;
  padding-top: 0;
}

.bonus-label, .time-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.bonus-value {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: 700;
}

.bonus-value.win {
  color: #ff6b6b;
}

.bonus-value.lose {
  color: #999;
}

.time-value {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 比赛列表 */
.match-item {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #f8f9fb;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
  transition: all 0.3s ease;
}

.match-item:active {
  background: #f0f2f8;
}

.match-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.match-num {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 700;
}

.match-time {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
  margin-left: auto;
}

.match-teams {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  background: #fff;
  padding: 12rpx;
  border-radius: 8rpx;
}

.team {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.team.away {
  text-align: right;
}

.team-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  line-height: 1.3;
}

.vs-box {
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60rpx;
}

.vs {
  font-size: 20rpx;
  color: #ccc;
  font-weight: 600;
}

/* 开奖结果 */
.match-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.option-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  border: none;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.option-item.miss {
  background: linear-gradient(135deg, #999 0%, #bbb 100%);
}

.opt-content {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.opt-type {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

.opt-value {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.opt-odds {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  white-space: nowrap;
}

.option-result {
  width: auto;
  max-width: 140rpx;
  padding: 8rpx 12rpx;
  background: #fff;
  border-radius: 6rpx;
  border-left: 3rpx solid #667eea;
  text-align: center;
  font-size: 20rpx;
  color: #333;
  font-weight: 600;
  transition: all 0.2s ease;
}

.option-result.hit {
  background: rgba(255, 107, 107, 0.12);
  border-left-color: #ff6b6b;
  color: #ff6b6b;
}

.option-result.pending {
  background: rgba(82, 196, 26, 0.12);
  border-left-color: #52c41a;
  color: #52c41a;
}

.option-result.miss {
  background: rgba(200, 200, 200, 0.08);
  border-left-color: #d9d9d9;
  color: #999;
}

.result-value {
  font-size: 20rpx;
  color: inherit;
  font-weight: 600;
}

.hit-icon {
  color: #ff6b6b;
  font-weight: 800;
  font-size: 20rpx;
  margin-left: 4rpx;
}

.miss-icon {
  color: #999;
  font-weight: 800;
  font-size: 20rpx;
  margin-left: 4rpx;
}

.bottom-placeholder {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* 底部推荐栏 */
.bottom-share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.95) 20%, #fff 100%);
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  backdrop-filter: blur(10px);
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  border: none;
  padding: 0;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
  transition: all 0.3s ease;
  font-size: 0;
}

.share-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.25);
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
}

.share-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}
