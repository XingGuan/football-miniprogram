<!-- components/quick-questions/index.wxml -->
<view class="quick-questions" wx:if="{{questionList.length > 0 || loading}}">
  <!-- 标题 -->
  <view class="header" wx:if="{{showTitle}}">
    <text class="title">{{title}}</text>
    <view class="refresh-btn" bindtap="refresh" wx:if="{{!loading}}">
      <text class="refresh-text">换一批</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 问题列表 -->
  <view class="question-list" wx:else>
    <view
      class="question-item"
      wx:for="{{questionList}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="onQuestionTap"
    >
      <text class="question-text">{{item}}</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
