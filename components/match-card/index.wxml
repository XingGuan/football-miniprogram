<!-- components/match-card/index.wxml -->
<view class="match-card {{isVip ? 'vip-card' : ''}}">
  <!-- VIP专属光效 -->
  <view class="vip-glow" wx:if="{{isVip}}"></view>

  <!-- 单场角标 -->
  <view class="single-badge" wx:if="{{match.isSingleMatch}}">单</view>

  <!-- 顶部信息 -->
  <view class="card-header">
    <view class="header-left">
      <text class="match-num">{{match.matchNumStr}}</text>
      <text class="league-tag" style="background-color: #{{match.leagueColor || '667eea'}}">{{match.league}}</text>
    </view>
    <view class="header-right">
      <!-- VIP标识 -->
      <view class="vip-tag" wx:if="{{isVip}}">
        <view class="vip-tag-diamond"></view>
        <text>VIP</text>
      </view>
      <text class="match-time">{{formattedTime}}</text>
    </view>
  </view>

  <!-- 球队信息 -->
  <view class="teams-row">
    <view class="team-info home">
      <text class="team-name">{{match.homeTeam}}</text>
      <text class="team-rank" wx:if="{{match.homeTeamRank}}">[{{match.homeTeamRank}}]</text>
    </view>
    <text class="vs">VS</text>
    <view class="team-info away">
      <text class="team-name">{{match.awayTeam}}</text>
      <text class="team-rank" wx:if="{{match.awayTeamRank}}">[{{match.awayTeamRank}}]</text>
    </view>
  </view>

  <!-- Tips提示 -->
  <view class="team-tip-bar" wx:if="{{showAiAnalysis && ((match.homeTags && match.homeTags.length) || (match.awayTags && match.awayTags.length) || match.homeFormTrend || match.awayFormTrend)}}" catchtap="onToggleTip">
    <view class="tip-label">
      <text class="tip-icon">💡</text>
      <text class="tip-text">Tips</text>
    </view>
    <text class="tip-arrow {{showTip ? 'expanded' : ''}}">›</text>
  </view>

  <!-- 展开的详情 -->
  <view class="team-detail-panel {{showTip ? 'show' : ''}}">
    <!-- 主队信息 -->
    <view class="team-detail-item">
      <view class="detail-header">
        <text class="detail-team-name">{{match.homeTeam}}</text>
        <view class="trend-badge {{match.homeFormTrend === '上升' ? 'up' : (match.homeFormTrend === '下降' ? 'down' : 'stable')}}" wx:if="{{match.homeFormTrend}}">
          <text class="trend-icon">{{match.homeFormTrend === '上升' ? '↑' : (match.homeFormTrend === '下降' ? '↓' : '→')}}</text>
          <text class="trend-text">{{match.homeFormTrend}}</text>
        </view>
      </view>
      <view class="detail-tags" wx:if="{{match.homeTags && match.homeTags.length}}">
        <text class="tag-item" wx:for="{{match.homeTags}}" wx:key="index">{{item}}</text>
      </view>
    </view>
    <!-- 客队信息 -->
    <view class="team-detail-item">
      <view class="detail-header">
        <text class="detail-team-name">{{match.awayTeam}}</text>
        <view class="trend-badge {{match.awayFormTrend === '上升' ? 'up' : (match.awayFormTrend === '下降' ? 'down' : 'stable')}}" wx:if="{{match.awayFormTrend}}">
          <text class="trend-icon">{{match.awayFormTrend === '上升' ? '↑' : (match.awayFormTrend === '下降' ? '↓' : '→')}}</text>
          <text class="trend-text">{{match.awayFormTrend}}</text>
        </view>
      </view>
      <view class="detail-tags" wx:if="{{match.awayTags && match.awayTags.length}}">
        <text class="tag-item" wx:for="{{match.awayTags}}" wx:key="index">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- AI分析 + 欧赔 (4列) -->
  <view class="odds-row">
    <view class="odds-cell action-cell {{isVip ? 'vip-unlocked' : (isUnlocked ? 'unlocked' : 'locked')}}" catchtap="onAnalyze" wx:if="{{showAiAnalysis}}">
      <view class="action-content">
        <text class="action-tag {{isVip ? 'vip-tag-text' : ''}}">AI</text>
        <text class="action-text">分析</text>
        <!-- VIP用户显示VIP图标，非VIP未解锁显示锁 -->
        <view class="vip-free-icon" wx:if="{{isVip}}">
          <view class="mini-diamond"></view>
        </view>
        <text class="lock-icon" wx:elif="{{!isUnlocked}}">🔒</text>
      </view>
    </view>
    <!-- AI分析隐藏时的占位 -->
    <view class="odds-cell action-cell-placeholder" wx:if="{{!showAiAnalysis}}"></view>
    <view class="odds-cell">
      <text class="odds-label">主胜</text>
      <text class="odds-num">{{match.odds.home || '-'}}</text>
    </view>
    <view class="odds-cell">
      <text class="odds-label">平局</text>
      <text class="odds-num">{{match.odds.draw || '-'}}</text>
    </view>
    <view class="odds-cell">
      <text class="odds-label">客胜</text>
      <text class="odds-num">{{match.odds.away || '-'}}</text>
    </view>
  </view>

  <!-- 查看详情 + 让球赔率 (4列) -->
  <view class="odds-row handicap-row" wx:if="{{match.odds.goalLine}}">
    <view class="odds-cell detail-cell" catchtap="onTap">
      <text class="detail-text">分析</text>
    </view>
    <view class="odds-cell goalline">
      <text class="goalline-label">让{{match.odds.goalLine}}</text>
      <text class="odds-num">{{match.odds.hhome || '-'}}</text>
    </view>
    <view class="odds-cell">
      <text class="odds-label">让平</text>
      <text class="odds-num">{{match.odds.hdraw || '-'}}</text>
    </view>
    <view class="odds-cell">
      <text class="odds-label">让客</text>
      <text class="odds-num">{{match.odds.haway || '-'}}</text>
    </view>
  </view>

  <!-- 无让球时的详情入口 -->
  <view class="odds-row" wx:else>
    <view class="odds-cell detail-cell full" catchtap="onTap">
      <text class="detail-text">分析</text>
    </view>
  </view>
</view>
