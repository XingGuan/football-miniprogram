<!-- custom-tab-bar/index.wxml -->
<view class="tab-bar">
  <block wx:for="{{list}}" wx:key="index">
    <!-- 历史tab根据showHistory控制显示 -->
    <view
      wx:if="{{item.key !== 'history' || showHistory}}"
      class="tab-bar-item"
      data-path="{{item.pagePath}}"
      bindtap="switchTab"
    >
      <image class="tab-bar-icon" src="{{selectedPath === item.pagePath ? item.selectedIconPath : item.iconPath}}"></image>
      <text class="tab-bar-text" style="color: {{selectedPath === item.pagePath ? selectedColor : color}}">{{item.text}}</text>
    </view>
  </block>
</view>
