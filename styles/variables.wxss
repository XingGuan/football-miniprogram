/* styles/variables.wxss - 样式变量 */

page {
  /* 主题色 */
  --primary-color: #1890ff;
  --primary-light: #e6f7ff;
  --primary-dark: #096dd9;

  /* 渐变色 */
  --gradient-primary: linear-gradient(135deg, #1890ff, #36cfc9);
  --gradient-success: linear-gradient(135deg, #52c41a, #73d13d);
  --gradient-warning: linear-gradient(135deg, #faad14, #ffc53d);
  --gradient-danger: linear-gradient(135deg, #ff4d4f, #ff7875);

  /* 功能色 */
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #ff4d4f;
  --info-color: #1890ff;

  --won-color: #fdecea;
  --pedding-color: #e6f7f1;
  --lost-color: #f4f4f5;

  --pedding-text-color: #54bb21;
  --won-text-color: #ff4d4f;
  --lost-text-color: #848080;

  /* 文字颜色 */
  --text-color: #333333;
  --text-secondary: #666666;
  --text-placeholder: #cccccc;
  --text-disabled: #999999;

  /* 背景色 */
  --bg-color: #f5f5f5;
  --bg-white: #ffffff;
  --bg-gray: #fafafa;

  /* 边框色 */
  --border-color: #f0f0f0;
  --border-light: #f5f5f5;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-round: 9999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 字体大小 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 40rpx;

  /* 行高 */
  --line-height-tight: 1.3;
  --line-height-normal: 1.5;
  --line-height-loose: 1.7;

  /* 动画 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.2s ease;
  --transition-slow: 0.3s ease;



  --bg-primary: #f1f4f8;
  --border-light: #e8ecf2;
  --card-text-primary: #1a1f2e;
  --text-tertiary: #8b90a0;
  --amount-orange: #f07b3f;
}