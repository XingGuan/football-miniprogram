<!-- pages/login/index.wxml -->
<view class="login-page">
  <!-- Logo 区域 -->
  <view class="logo-section">
    <image class="logo" src="/images/logo.png" mode="aspectFit" />
    <text class="app-name">足球分析助手</text>
    <text class="app-desc">智能 AI 分析，助你决策</text>
    <text>test</text>
  </view>

  <!-- 登录表单 -->
  <view class="form-section">
    <!-- 手机号 -->
    <view class="form-item">
      <view class="input-wrapper">
        <text class="input-prefix">+86</text>
        <input class="input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder"
          value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <!-- 验证码 -->
    <view class="form-item">
      <view class="input-wrapper code-wrapper">
        <input class="input code-input" type="number" maxlength="6" placeholder="请输入验证码" placeholder-class="placeholder"
          value="{{code}}" bindinput="onCodeInput" />
        <view class="send-code-btn {{countdown > 0 || sendingCode ? 'disabled' : ''}}" bindtap="onSendCode">
          <text class="send-code-text" wx:if="{{countdown > 0}}">{{countdown}}s</text>
          <text class="send-code-text" wx:elif="{{sendingCode}}">发送中...</text>
          <text class="send-code-text" wx:else>获取验证码</text>
        </view>
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn-wrapper">
      <button class="login-btn {{loading ? 'loading' : ''}}" bindtap="onLogin" disabled="{{loading}}">
        <text class="btn-text">{{loading ? '登录中...' : '登录'}}</text>
      </button>
    </view>

    <!-- 协议勾选 -->
    <view class="agreement-section">
      <checkbox-group bindchange="onAgreeChange">
        <label class="agreement-label">
          <checkbox value="agreed" checked="{{agreed}}" color="#1890ff" />
          <text class="agreement-text">我已阅读并同意</text>
          <text class="link" bindtap="onViewAgreement">《用户协议》</text>
          <text class="agreement-text">和</text>
          <text class="link" bindtap="onViewPrivacy">《隐私政策》</text>
        </label>
      </checkbox-group>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-section">
    <text class="footer-text">未注册手机号验证后将自动创建账号</text>
  </view>
</view>
